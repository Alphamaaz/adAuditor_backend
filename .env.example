# ───────────────────────────────────────────────────────────────────────────
# Core
# ───────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://ad_auditor:ad_auditor_password@localhost:5432/ad_auditor_dev?schema=public"
PORT=5000
NODE_ENV=development

# Frontend origin for CORS + redirect URLs
CLIENT_ORIGIN=http://localhost:3000
APP_URL=http://localhost:3000

# Local storage for generated PDFs
PDF_STORAGE_DIR=storage/pdf-reports

# ───────────────────────────────────────────────────────────────────────────
# Auth
# ───────────────────────────────────────────────────────────────────────────
SESSION_TTL_DAYS=30
# Cross-subdomain session: set to ".yourdomain.com" so app.x.com + api.x.com
# share the cookie. Omit for single-host deploys (default + safest).
# SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SAMESITE=lax

# ───────────────────────────────────────────────────────────────────────────
# Storage
# ───────────────────────────────────────────────────────────────────────────
STORAGE_DRIVER=local
STORAGE_ROOT=storage
# Set true once you have mounted STORAGE_ROOT from a persistent volume.
# In production with local driver, server will log a warning if unset.
STORAGE_PERSISTENT=false

# ───────────────────────────────────────────────────────────────────────────
# Encryption
# ───────────────────────────────────────────────────────────────────────────
# 64-character hex string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ───────────────────────────────────────────────────────────────────────────
# Stuck-audit reconciliation
# ───────────────────────────────────────────────────────────────────────────
STUCK_AUDIT_THRESHOLD_MS=900000        # 15 min
STUCK_AUDIT_RECONCILE_INTERVAL_MS=300000  # 5 min

# ───────────────────────────────────────────────────────────────────────────
# Shutdown timing
# ───────────────────────────────────────────────────────────────────────────
SHUTDOWN_TIMEOUT_MS=30000
HTTP_KEEPALIVE_MS=65000
HTTP_HEADERS_MS=66000

# ───────────────────────────────────────────────────────────────────────────
# AI cost caps
# ───────────────────────────────────────────────────────────────────────────
# Global daily ceiling (USD). Returns 503 to ALL AI requests when reached.
# 0 = disabled. Recommend setting in production as a safety net.
AI_GLOBAL_DAILY_USD_CAP=100

# PII redaction before sending context to LLM providers.
# Recommended "true" if any EU/UK customers or before SOC 2 observation.
AI_PII_REDACTION=false

# ───────────────────────────────────────────────────────────────────────────
# Job queue (bull = separate worker process, inline = same process)
# ───────────────────────────────────────────────────────────────────────────
JOB_QUEUE_DRIVER=inline
# Required when JOB_QUEUE_DRIVER=bull (separate worker process via `npm run worker`).
# In inline mode the API processes jobs itself; the stuck-audit reconciliation
# cron recovers anything lost to a restart.
REDIS_URL=redis://localhost:6379

# ───────────────────────────────────────────────────────────────────────────
# AI providers
# Options: gemini | openai | deepseek
# Production recommendation: gemini (cost) or openai (quality)
# ───────────────────────────────────────────────────────────────────────────
AI_PROVIDER=gemini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_TIMEOUT_MS=45000
GEMINI_MAX_OUTPUT_TOKENS=4000
GEMINI_TEMPERATURE=0.2

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=45000

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_MS=45000
DEEPSEEK_MAX_TOKENS=4000
DEEPSEEK_TEMPERATURE=0.2

# Anthropic Claude — recommended for Pro+ audit narratives.
# Set AI_PROVIDER=anthropic to use it. Falls back gracefully if key absent.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_TIMEOUT_MS=60000
ANTHROPIC_MAX_TOKENS=4000
ANTHROPIC_TEMPERATURE=0.2

# Fallback per-1M-token cost when a model isn't in the pricing table.
# Conservative defaults; tune if you use exotic models.
AI_FALLBACK_INPUT_USD_PER_M=1.0
AI_FALLBACK_OUTPUT_USD_PER_M=3.0

# ───────────────────────────────────────────────────────────────────────────
# Billing — Stripe
# Required for paid customers. Without these, /api/billing/* returns 503.
# ───────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
# Endpoint signing secret from Stripe dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=

# ───────────────────────────────────────────────────────────────────────────
# Observability — Sentry
# Optional in dev. Required in production.
# ───────────────────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0

# ───────────────────────────────────────────────────────────────────────────
# Rule engine — dual-write shadow mode
# Set to "true" to run the new rule engine in parallel with the legacy
# engine. Telemetry-only — does NOT change customer-facing findings.
# ───────────────────────────────────────────────────────────────────────────
RULE_ENGINE_DUAL_WRITE=false

# ───────────────────────────────────────────────────────────────────────────
# SMTP — transactional email
# ───────────────────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="AdAuditor Pro <no-reply@example.com>"

# ───────────────────────────────────────────────────────────────────────────
# Prisma — optional
# ───────────────────────────────────────────────────────────────────────────
# PRISMA_LOG_QUERIES=false
